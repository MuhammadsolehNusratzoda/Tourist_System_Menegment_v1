@page "/login"
@inject ClientAuthService AuthSvc
@inject NavigationManager Nav

<PageTitle>Sign In — TouristSystem</PageTitle>

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-logo">
            <a href="/" class="ts-brand" style="justify-content:center; font-size:1.75rem;">
                <i class="bi bi-globe-asia-australia"></i> TouristSystem
            </a>
        </div>

        <h1 class="auth-title">Welcome Back</h1>
        <p class="auth-subtitle">Sign in to manage your bookings and explore Tajikistan</p>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="ts-alert ts-alert-error">
                <i class="bi bi-exclamation-triangle"></i> @errorMessage
            </div>
        }

        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="ts-alert ts-alert-success">
                <i class="bi bi-check-circle"></i> @successMessage
            </div>
        }

        <EditForm Model="model" OnValidSubmit="HandleLogin">
            <DataAnnotationsValidator />

            <div class="ts-form-group">
                <label class="ts-label">Email Address</label>
                <div style="position:relative;">
                    <i class="bi bi-envelope" style="position:absolute; left:0.875rem; top:50%; transform:translateY(-50%); color:var(--color-text-dim);"></i>
                    <InputText @bind-Value="model.Email" class="ts-input" style="padding-left:2.5rem;" placeholder="you@example.com" type="email" />
                </div>
                <ValidationMessage For="@(() => model.Email)" class="validation-message" />
            </div>

            <div class="ts-form-group">
                <label class="ts-label">Password</label>
                <div style="position:relative;">
                    <i class="bi bi-lock" style="position:absolute; left:0.875rem; top:50%; transform:translateY(-50%); color:var(--color-text-dim);"></i>
                    <InputText @bind-Value="model.Password" class="ts-input" style="padding-left:2.5rem;" placeholder="Your password" type="@(showPassword ? "text" : "password")" />
                    <button type="button" @onclick="TogglePassword" style="position:absolute; right:0.875rem; top:50%; transform:translateY(-50%); background:none; border:none; color:var(--color-text-dim); cursor:pointer;">
                        <i class="bi @(showPassword ? "bi-eye-slash" : "bi-eye")"></i>
                    </button>
                </div>
                <ValidationMessage For="@(() => model.Password)" class="validation-message" />
            </div>

            <button type="submit" class="btn-ts btn-primary-ts" style="width:100%; justify-content:center; margin-top:0.5rem;" disabled="@loading">
                @if (loading)
                {
                    <span style="display:inline-block; width:16px; height:16px; border:2px solid rgba(255,255,255,0.3); border-top-color:#fff; border-radius:50%; animation:spin 0.8s linear infinite;"></span>
                    <span>Signing in...</span>
                }
                else
                {
                    <i class="bi bi-box-arrow-in-right"></i>
                    <span>Sign In</span>
                }
            </button>
        </EditForm>

        <div style="text-align:center; margin-top:1.5rem; color:var(--color-text-muted); font-size:0.875rem;">
            Don't have an account?
            <a href="/register" style="color:var(--color-accent-2); font-weight:600; margin-left:0.25rem;">Create Account</a>
        </div>

        <div style="margin-top:1.5rem; padding:1rem; background:var(--color-surface-2); border-radius:var(--radius-md); font-size:0.8rem; color:var(--color-text-dim);">
            <i class="bi bi-info-circle" style="color:var(--color-accent-2);"></i>
            <strong style="color:var(--color-text-muted);">Demo Mode:</strong> When the API is offline, the app uses demo data so you can explore all features.
        </div>
    </div>
</div>

@code {
    private LoginRequest model = new();
    private string errorMessage = "";
    private string successMessage = "";
    private bool loading = false;
    private bool showPassword = false;

    private async Task HandleLogin()
    {
        loading = true;
        errorMessage = "";
        successMessage = "";

        var (success, message) = await AuthSvc.LoginAsync(model);

        if (success)
        {
            successMessage = message;
            await Task.Delay(800);
            Nav.NavigateTo("/", forceLoad: true);
        }
        else
        {
            errorMessage = message;
        }

        loading = false;
    }

    private void TogglePassword() => showPassword = !showPassword;
}

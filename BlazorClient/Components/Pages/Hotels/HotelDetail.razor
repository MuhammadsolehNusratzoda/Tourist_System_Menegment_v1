@page "/hotels/{Id:guid}"
@inject HotelClientService HotelSvc
@inject ReviewClientService ReviewSvc
@inject NavigationManager Nav

<PageTitle>@(hotel?.Name ?? "Hotel") — TouristSystem</PageTitle>

@if (loading)
{
    <div class="ts-spinner" style="min-height:60vh;"><div class="spinner"></div></div>
}
else if (hotel == null)
{
    <div class="ts-container" style="text-align:center; padding:6rem 2rem;">
        <i class="bi bi-building-x" style="font-size:4rem; color:var(--color-text-dim); display:block; margin-bottom:1rem;"></i>
        <h2 style="color:#fff;">Hotel Not Found</h2>
        <a href="/hotels" class="btn-ts btn-primary-ts" style="margin-top:1rem;">← Back to Hotels</a>
    </div>
}
else
{
    <div class="ts-container" style="padding:2rem 1.5rem 4rem;">
        <!-- Breadcrumb -->
        <div style="display:flex; align-items:center; gap:0.5rem; color:var(--color-text-muted); font-size:0.875rem; margin-bottom:1.5rem;">
            <a href="/hotels" style="color:var(--color-text-muted);">Hotels</a>
            <i class="bi bi-chevron-right" style="font-size:0.75rem;"></i>
            <span style="color:#fff;">@hotel.Name</span>
        </div>

        <div style="display:grid; grid-template-columns:1fr 340px; gap:2.5rem; align-items:start;">
            <!-- Left: Details -->
            <div>
                <img class="detail-hero" src="@(hotel.ImageUrl ?? "https://images.unsplash.com/photo-1566073771259-6a8506099945?w=800")" alt="@hotel.Name" />

                <h1 class="detail-title">@hotel.Name</h1>

                <div class="detail-meta">
                    <span class="detail-meta-item" style="color:var(--color-gold);">
                        <i class="bi bi-star-fill"></i> @hotel.Rating.ToString("F1") Rating
                    </span>
                    <span class="detail-meta-item">
                        <i class="bi bi-geo-alt"></i> @hotel.Location
                    </span>
                    <span class="detail-meta-item" style="color:var(--color-gold);">
                        @hotel.StarsDisplay
                    </span>
                    <span class="detail-meta-item">
                        <i class="bi bi-calendar"></i> Added @hotel.CreatedAt.ToString("MMM yyyy")
                    </span>
                </div>

                <p class="detail-desc">@hotel.Description</p>

                <!-- Amenities -->
                <div style="margin-top:2rem;">
                    <h3 style="color:#fff; margin-bottom:1rem;">Amenities</h3>
                    <div style="display:flex; flex-wrap:wrap; gap:0.75rem;">
                        @foreach (var amenity in GetAmenities(hotel.Stars))
                        {
                            <span class="ts-badge badge-accent"><i class="bi @amenity.icon"></i> @amenity.name</span>
                        }
                    </div>
                </div>

                <!-- Reviews -->
                <div style="margin-top:2.5rem;">
                    <h3 style="color:#fff; margin-bottom:1.25rem;">Guest Reviews</h3>
                    @if (reviews.Count == 0)
                    {
                        <p style="color:var(--color-text-muted);">No reviews yet. Be the first to review!</p>
                    }
                    else
                    {
                        <div style="display:flex; flex-direction:column; gap:1rem;">
                            @foreach (var review in reviews)
                            {
                                <div class="review-card">
                                    <div class="review-header">
                                        <div>
                                            <div class="reviewer-name">@review.UserName</div>
                                            <div class="stars">@review.StarsDisplay</div>
                                        </div>
                                        <div class="review-date">@review.CreatedAt.ToString("MMM d, yyyy")</div>
                                    </div>
                                    <p class="review-text">@review.Comment</p>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>

            <!-- Right: Booking Sidebar -->
            <div style="position:sticky; top:90px;">
                <div class="ts-card" style="padding:2rem;">
                    <div style="margin-bottom:1.5rem;">
                        <div class="ts-card-price" style="font-size:2rem;">$@hotel.PricePerNight <span>/ night</span></div>
                        <div style="display:flex; align-items:center; gap:0.5rem; margin-top:0.5rem;">
                            <i class="bi bi-star-fill" style="color:var(--color-gold);"></i>
                            <span style="font-weight:600; color:#fff;">@hotel.Rating.ToString("F1")</span>
                            <span style="color:var(--color-text-muted); font-size:0.85rem;">· @hotel.StarsDisplay</span>
                        </div>
                    </div>

                    <div style="border:1px solid var(--color-border); border-radius:var(--radius-md); overflow:hidden; margin-bottom:1rem;">
                        <div style="display:grid; grid-template-columns:1fr 1fr;">
                            <div style="padding:0.875rem; border-right:1px solid var(--color-border);">
                                <div style="font-size:0.7rem; font-weight:700; text-transform:uppercase; color:var(--color-text-muted); margin-bottom:0.25rem;">Check-in</div>
                                <input type="date" @bind="checkIn" class="ts-input" style="border:none; padding:0; background:none; font-weight:600; color:#fff; font-size:0.95rem;" />
                            </div>
                            <div style="padding:0.875rem;">
                                <div style="font-size:0.7rem; font-weight:700; text-transform:uppercase; color:var(--color-text-muted); margin-bottom:0.25rem;">Check-out</div>
                                <input type="date" @bind="checkOut" class="ts-input" style="border:none; padding:0; background:none; font-weight:600; color:#fff; font-size:0.95rem;" />
                            </div>
                        </div>
                    </div>

                    @if (nights > 0)
                    {
                        <div style="display:flex; justify-content:space-between; align-items:center; padding:0.75rem 0; border-top:1px solid var(--color-border); margin-top:0.5rem;">
                            <span style="color:var(--color-text-muted);">$@hotel.PricePerNight × @nights nights</span>
                            <span style="color:#fff; font-weight:700;">$@(hotel.PricePerNight * nights)</span>
                        </div>
                    }

                    <a href="/bookings/create?type=Hotel&id=@hotel.Id" class="btn-ts btn-primary-ts" style="width:100%; justify-content:center; margin-top:1rem;">
                        <i class="bi bi-calendar-check"></i> Book This Hotel
                    </a>

                    <div style="text-align:center; margin-top:1rem; color:var(--color-text-dim); font-size:0.8rem;">
                        <i class="bi bi-shield-check" style="color:var(--color-success);"></i> Free cancellation · No prepayment
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private HotelDto? hotel;
    private List<ReviewDto> reviews = new();
    private bool loading = true;
    private DateTime checkIn = DateTime.Today;
    private DateTime checkOut = DateTime.Today.AddDays(3);

    private int nights => checkOut > checkIn ? (checkOut - checkIn).Days : 0;

    protected override async Task OnInitializedAsync()
    {
        hotel = await HotelSvc.GetByIdAsync(Id);
        if (hotel != null)
            reviews = await ReviewSvc.GetReviewsAsync("Hotel", Id);
        loading = false;
    }

    private List<(string icon, string name)> GetAmenities(int stars) => stars switch
    {
        5 => new() { ("bi-wifi", "Free WiFi"), ("bi-p-square", "Parking"), ("bi-cup-hot", "Breakfast"), ("bi-thermometer-snow", "AC"), ("bi-activity", "Gym"), ("bi-droplet", "Pool"), ("bi-shield-check", "24/7 Security"), ("bi-car-front", "Airport Transfer") },
        4 => new() { ("bi-wifi", "Free WiFi"), ("bi-p-square", "Parking"), ("bi-cup-hot", "Breakfast"), ("bi-thermometer-snow", "AC"), ("bi-shield-check", "24/7 Security") },
        3 => new() { ("bi-wifi", "Free WiFi"), ("bi-cup-hot", "Breakfast"), ("bi-thermometer-snow", "AC") },
        _ => new() { ("bi-wifi", "Free WiFi"), ("bi-cup-hot", "Breakfast") }
    };
}

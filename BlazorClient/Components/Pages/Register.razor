@page "/register"
@inject ClientAuthService AuthSvc
@inject NavigationManager Nav

<PageTitle>Create Account — TouristSystem</PageTitle>

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-logo">
            <a href="/" class="ts-brand" style="justify-content:center; font-size:1.75rem;">
                <i class="bi bi-globe-asia-australia"></i> TouristSystem
            </a>
        </div>

        <h1 class="auth-title">Create Account</h1>
        <p class="auth-subtitle">Join thousands of travelers exploring Tajikistan</p>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="ts-alert ts-alert-error">
                <i class="bi bi-exclamation-triangle"></i> @errorMessage
            </div>
        }

        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="ts-alert ts-alert-success">
                <i class="bi bi-check-circle"></i> @successMessage
            </div>
        }

        <EditForm Model="@model" OnValidSubmit="@HandleRegister" FormName="registerForm">
            <DataAnnotationsValidator />

            <div class="ts-form-group">
                <label class="ts-label">Full Name</label>
                <div style="position:relative;">
                    <i class="bi bi-person" style="position:absolute; left:0.875rem; top:50%; transform:translateY(-50%); color:var(--color-text-dim);"></i>
                    <InputText @bind-Value="model.FullName" class="ts-input" style="padding-left:2.5rem;" placeholder="Your full name" />
                </div>
                <ValidationMessage For="@(() => model.FullName)" class="validation-message" />
            </div>

            <div class="ts-form-group">
                <label class="ts-label">Email Address</label>
                <div style="position:relative;">
                    <i class="bi bi-envelope" style="position:absolute; left:0.875rem; top:50%; transform:translateY(-50%); color:var(--color-text-dim);"></i>
                    <InputText @bind-Value="model.Email" class="ts-input" style="padding-left:2.5rem;" placeholder="you@example.com" type="email" />
                </div>
                <ValidationMessage For="@(() => model.Email)" class="validation-message" />
            </div>

            <div class="ts-form-group">
                <label class="ts-label">Phone Number <span style="color:var(--color-text-dim); font-weight:400;">(optional)</span></label>
                <div style="position:relative;">
                    <i class="bi bi-telephone" style="position:absolute; left:0.875rem; top:50%; transform:translateY(-50%); color:var(--color-text-dim);"></i>
                    <InputText @bind-Value="model.PhoneNumber" class="ts-input" style="padding-left:2.5rem;" placeholder="+992 xxx xxx xxx" />
                </div>
            </div>

            <div class="ts-form-group">
                <label class="ts-label">Password</label>
                <div style="position:relative;">
                    <i class="bi bi-lock" style="position:absolute; left:0.875rem; top:50%; transform:translateY(-50%); color:var(--color-text-dim);"></i>
                    <InputText @bind-Value="model.Password" class="ts-input" style="padding-left:2.5rem;" placeholder="At least 6 characters" type="@(showPassword ? "text" : "password")" />
                    <button type="button" @onclick="TogglePassword" style="position:absolute; right:0.875rem; top:50%; transform:translateY(-50%); background:none; border:none; color:var(--color-text-dim); cursor:pointer;">
                        <i class="bi @(showPassword ? "bi-eye-slash" : "bi-eye")"></i>
                    </button>
                </div>
                <ValidationMessage For="@(() => model.Password)" class="validation-message" />
            </div>

            <!-- Password strength -->
            @if (!string.IsNullOrEmpty(model.Password))
            {
                var strength = GetPasswordStrength(model.Password);
                <div style="margin-top:-0.5rem; margin-bottom:1rem;">
                    <div style="height:4px; border-radius:2px; background:var(--color-border); overflow:hidden;">
                        <div style="height:100%; width:@(strength.percent)%; background:@strength.color; border-radius:2px; transition:all 0.3s;"></div>
                    </div>
                    <div style="font-size:0.75rem; color:@strength.color; margin-top:0.25rem;">@strength.label</div>
                </div>
            }

            <button type="submit" class="btn-ts btn-primary-ts" style="width:100%; justify-content:center; margin-top:0.5rem;" disabled="@loading">
                @if (loading)
                {
                    <span style="display:inline-block; width:16px; height:16px; border:2px solid rgba(255,255,255,0.3); border-top-color:#fff; border-radius:50%; animation:spin 0.8s linear infinite;"></span>
                    <span>Creating account...</span>
                }
                else
                {
                    <i class="bi bi-person-plus"></i>
                    <span>Create Account</span>
                }
            </button>
        </EditForm>

        <div style="text-align:center; margin-top:1.5rem; color:var(--color-text-muted); font-size:0.875rem;">
            Already have an account?
            <a href="/login" style="color:var(--color-accent-2); font-weight:600; margin-left:0.25rem;">Sign In</a>
        </div>
    </div>
</div>

@code {
    private RegisterRequest model = new();
    private string errorMessage = "";
    private string successMessage = "";
    private bool loading = false;
    private bool showPassword = false;

    private async Task HandleRegister()
    {
        loading = true;
        errorMessage = "";
        successMessage = "";

        var (success, message) = await AuthSvc.RegisterAsync(model);

        if (success)
        {
            successMessage = "Account created! Redirecting...";
            await Task.Delay(1000);
            Nav.NavigateTo("/", forceLoad: true);
        }
        else
        {
            errorMessage = message;
        }

        loading = false;
    }

    private void TogglePassword() => showPassword = !showPassword;

    private (string percent, string color, string label) GetPasswordStrength(string pwd)
    {
        int score = 0;
        if (pwd.Length >= 6) score++;
        if (pwd.Length >= 10) score++;
        if (pwd.Any(char.IsUpper)) score++;
        if (pwd.Any(char.IsDigit)) score++;
        if (pwd.Any(c => !char.IsLetterOrDigit(c))) score++;

        return score switch
        {
            <= 1 => ("20", "var(--color-danger)", "Weak"),
            2 => ("40", "#f97316", "Fair"),
            3 => ("60", "var(--color-warning)", "Good"),
            4 => ("80", "var(--color-success)", "Strong"),
            _ => ("100", "#10b981", "Very Strong")
        };
    }
}

@page "/places/{Id:guid}"
@inject PlaceClientService PlaceSvc
@inject ReviewClientService ReviewSvc

<PageTitle>@(place?.Name ?? "Place") — TouristSystem</PageTitle>

@if (loading)
{
    <div class="ts-spinner" style="min-height:60vh;"><div class="spinner"></div></div>
}
else if (place == null)
{
    <div class="ts-container" style="text-align:center; padding:6rem 2rem;">
        <i class="bi bi-map" style="font-size:4rem; color:var(--color-text-dim); display:block; margin-bottom:1rem;"></i>
        <h2 style="color:#fff;">Place Not Found</h2>
        <a href="/places" class="btn-ts btn-primary-ts" style="margin-top:1rem;">← Back to Places</a>
    </div>
}
else
{
    <div class="ts-container" style="padding:2rem 1.5rem 4rem;">
        <!-- Breadcrumb -->
        <div style="display:flex; align-items:center; gap:0.5rem; color:var(--color-text-muted); font-size:0.875rem; margin-bottom:1.5rem;">
            <a href="/places" style="color:var(--color-text-muted);">Places</a>
            <i class="bi bi-chevron-right" style="font-size:0.75rem;"></i>
            <span style="color:#fff;">@place.Name</span>
        </div>

        <img class="detail-hero" src="@(place.ImageUrl ?? "https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?w=800")" alt="@place.Name" />

        <div style="display:grid; grid-template-columns:1fr 300px; gap:2.5rem; align-items:start;">
            <div>
                <h1 class="detail-title">@place.Name</h1>

                <div class="detail-meta">
                    <span class="detail-meta-item" style="color:var(--color-gold);">
                        <i class="bi bi-star-fill"></i> @place.Rating.ToString("F1") Rating
                    </span>
                    <span class="detail-meta-item">
                        <i class="bi bi-geo-alt"></i> @place.Location
                    </span>
                    @if (place.EntryFee > 0)
                    {
                        <span class="detail-meta-item">
                            <i class="bi bi-ticket"></i> $@place.EntryFee entry fee
                        </span>
                    }
                    else
                    {
                        <span class="detail-meta-item" style="color:var(--color-success);">
                            <i class="bi bi-check-circle"></i> Free Entry
                        </span>
                    }
                </div>

                <p class="detail-desc">@place.Description</p>

                @if (place.Latitude.HasValue && place.Longitude.HasValue)
                {
                    <div style="margin-top:2rem; padding:1.5rem; background:var(--color-surface); border:1px solid var(--color-border); border-radius:var(--radius-lg);">
                        <h4 style="color:#fff; margin-bottom:0.75rem;"><i class="bi bi-map" style="color:var(--color-accent-2);"></i> Location</h4>
                        <div style="display:flex; gap:1rem; flex-wrap:wrap;">
                            <span style="color:var(--color-text-muted); font-size:0.875rem;"><i class="bi bi-crosshair"></i> Lat: @place.Latitude?.ToString("F4")</span>
                            <span style="color:var(--color-text-muted); font-size:0.875rem;"><i class="bi bi-crosshair2"></i> Lng: @place.Longitude?.ToString("F4")</span>
                        </div>
                        <a href="https://www.google.com/maps?q=@place.Latitude,@place.Longitude" target="_blank" class="btn-ts btn-secondary-ts btn-sm-ts" style="margin-top:1rem;">
                            <i class="bi bi-map-fill"></i> Open in Google Maps
                        </a>
                    </div>
                }

                <!-- Reviews -->
                <div style="margin-top:2.5rem;">
                    <h3 style="color:#fff; margin-bottom:1.25rem;">Visitor Reviews</h3>
                    @if (reviews.Count == 0)
                    {
                        <p style="color:var(--color-text-muted);">No reviews yet. Be the first!</p>
                    }
                    else
                    {
                        <div style="display:flex; flex-direction:column; gap:1rem;">
                            @foreach (var review in reviews)
                            {
                                <div class="review-card">
                                    <div class="review-header">
                                        <div>
                                            <div class="reviewer-name">@review.UserName</div>
                                            <div class="stars">@review.StarsDisplay</div>
                                        </div>
                                        <div class="review-date">@review.CreatedAt.ToString("MMM d, yyyy")</div>
                                    </div>
                                    <p class="review-text">@review.Comment</p>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>

            <!-- Sidebar -->
            <div style="position:sticky; top:90px;">
                <div class="ts-card" style="padding:1.75rem;">
                    <h4 style="color:#fff; margin-bottom:1.25rem;">Plan Your Visit</h4>
                    <div style="display:flex; flex-direction:column; gap:0.875rem; margin-bottom:1.5rem;">
                        <div style="display:flex; justify-content:space-between;">
                            <span style="color:var(--color-text-muted); font-size:0.875rem;">Entry Fee</span>
                            <span style="color:#fff; font-weight:700;">@(place.EntryFee == 0 ? "Free" : "$" + place.EntryFee)</span>
                        </div>
                        <div style="display:flex; justify-content:space-between;">
                            <span style="color:var(--color-text-muted); font-size:0.875rem;">Rating</span>
                            <span style="color:var(--color-gold); font-weight:700;"><i class="bi bi-star-fill"></i> @place.Rating.ToString("F1")</span>
                        </div>
                        <div style="display:flex; justify-content:space-between;">
                            <span style="color:var(--color-text-muted); font-size:0.875rem;">Location</span>
                            <span style="color:#fff; font-weight:600; font-size:0.875rem;">@place.Location</span>
                        </div>
                    </div>
                    <a href="/guides" class="btn-ts btn-primary-ts" style="width:100%; justify-content:center; margin-bottom:0.75rem;">
                        <i class="bi bi-person-badge"></i> Find a Guide
                    </a>
                    <a href="/bookings/create?type=Guide" class="btn-ts btn-secondary-ts" style="width:100%; justify-content:center;">
                        <i class="bi bi-calendar-plus"></i> Book Tour
                    </a>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public Guid Id { get; set; }
    private PlaceDto? place;
    private List<ReviewDto> reviews = new();
    private bool loading = true;

    protected override async Task OnInitializedAsync()
    {
        place = await PlaceSvc.GetByIdAsync(Id);
        if (place != null)
            reviews = await ReviewSvc.GetReviewsAsync("Place", Id);
        loading = false;
    }
}
